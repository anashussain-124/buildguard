# ── Backend (Railway) ────────────────────────────────────────────────────
SUPABASE_URL=CHANGE_ME
SUPABASE_ANON_KEY=CHANGE_ME             # Public anon key (safe for frontend, used with RLS)
SUPABASE_SERVICE_KEY=CHANGE_ME          # Service role key (admin, bypasses RLS — NEVER expose to client)
OPENROUTER_API_KEY=CHANGE_ME            # API key from openrouter.ai
JWT_SECRET=CHANGE_ME                    # Random string for JWT signing (min 32 chars)
JWT_SECRET_PREVIOUS=CHANGE_ME           # Only needed during key rotation
ENVIRONMENT=production                  # Set to "production" on Railway
ALLOWED_ORIGINS=CHANGE_ME               # Comma-separated: https://your-domain.in,https://frontend-mu-drab-54.vercel.app
PORT=8000                               # Railway overrides this automatically

# ── Frontend (Vercel) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=CHANGE_ME            # https://backend-production-cfa2b.up.railway.app

# ── Optional: Redis (Upstash) ────────────────────────────────────────────
UPSTASH_REDIS_URL=CHANGE_ME
UPSTASH_REDIS_TOKEN=CHANGE_ME

# ── Optional: Error monitoring (Sentry) ──────────────────────────────────
SENTRY_DSN=CHANGE_ME
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME

# ── E2E Tests only ───────────────────────────────────────────────────────
E2E_TEST_PASSWORD=CHANGE_ME              # Never commit real value
