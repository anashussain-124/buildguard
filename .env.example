SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
OPENROUTER_API_KEY=your_openrouter_api_key
JWT_SECRET=your_jwt_secret
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
# FIX: GAP-07 — JWT key rotation support (set during rotation, then remove)
JWT_SECRET_PREVIOUS=CHANGE_ME     # See ROTATE_SECRETS.md for procedure
# FIX: GAP-01 — Distributed rate limiting (recommended for production)
UPSTASH_REDIS_URL=CHANGE_ME       # From Upstash console → REST API URL
UPSTASH_REDIS_TOKEN=CHANGE_ME     # From Upstash console → REST API Token
# FIX: GAP-02 — Error monitoring (recommended for production)
SENTRY_DSN=CHANGE_ME              # Backend DSN from sentry.io project settings
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME  # Frontend DSN from sentry.io
SENTRY_AUTH_TOKEN=CHANGE_ME       # Sentry CLI auth token for source map upload (CI only)
